# Private-beta deployment core
NEXT_PUBLIC_SITE_URL=https://riddra.com
NEXT_PUBLIC_LAUNCH_MODE=private_beta
# Optional: force protected surfaces open pre-live (`true`) or closed (`false`).
# If unset, the app keeps them open until `full_launch`.
OPEN_ADMIN_ACCESS=false
LOCAL_AUTH_BYPASS=false
ADMIN_EMAILS=ops@example.com,founder@example.com

# Supabase auth and stored-record continuity
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=replace-with-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=replace-with-supabase-service-role-key

# Market-data refresh and retained history
MARKET_DATA_REFRESH_SECRET=replace-with-market-data-refresh-secret
CRON_SECRET=replace-with-market-data-cron-secret
MARKET_DATA_PROVIDER_URL=https://market-data.example.com/v1/snapshot
MARKET_DATA_PROVIDER_TOKEN=replace-with-market-data-provider-token

# Durable jobs
TRIGGER_SECRET_KEY=replace-with-trigger-secret-key
TRIGGER_PROJECT_REF=replace-with-trigger-project-ref

# Search engine
MEILISEARCH_HOST=https://search.example.com
MEILISEARCH_API_KEY=replace-with-meilisearch-api-key
MEILISEARCH_INDEX_PREFIX=riddra_private_beta

# AI services
OPENAI_API_KEY=
AI_DEFAULT_MODE=formula_first
AI_REAL_CALLS_ENABLED=false
AI_BUDGET_PROFILE=minimal

# Transactional email and support delivery
RESEND_API_KEY=replace-with-resend-api-key
RESEND_FROM_EMAIL=Riddra Beta <beta@updates.example.com>
RESEND_REPLY_TO_EMAIL=support@example.com
NEXT_PUBLIC_SUPPORT_EMAIL=support@example.com

# Deferred commercial billing
RAZORPAY_KEY_ID=replace-with-razorpay-key-id
RAZORPAY_KEY_SECRET=replace-with-razorpay-key-secret
RAZORPAY_WEBHOOK_SECRET=replace-with-razorpay-webhook-secret

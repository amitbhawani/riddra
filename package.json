{
  "name": "riddra",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "node scripts/run-dev-stable.mjs",
    "dev:health": "node scripts/check-local-dev.mjs",
    "qa:public-routes": "node scripts/check-public-route-discipline.mjs",
    "qa:sitemap": "node scripts/audit-sitemap-routes.mjs",
    "qa:browser-perf": "node scripts/audit-browser-performance.mjs",
    "build": "node scripts/run-build-stable.mjs",
    "local:stable": "npm run build && next start",
    "start": "next start",
    "lint": "tsc --noEmit",
    "yahoo:sample": "node --env-file=.env.local scripts/import-yahoo-sample-stock.mjs",
    "yahoo:sample:reliance": "node --env-file=.env.local scripts/import-yahoo-sample-stock.mjs RELIANCE.NS",
    "yahoo:financials": "node --env-file=.env.local scripts/import-yahoo-financial-statements.mjs",
    "yahoo:financials:reliance": "node --env-file=.env.local scripts/import-yahoo-financial-statements.mjs RELIANCE.NS",
    "yahoo:quote-stats": "node --env-file=.env.local scripts/import-yahoo-quote-stats.mjs",
    "yahoo:quote-stats:reliance": "node --env-file=.env.local scripts/import-yahoo-quote-stats.mjs RELIANCE.NS",
    "yahoo:history": "node --env-file=.env.local scripts/import-yahoo-historical.mjs",
    "yahoo:history:reliance": "node --env-file=.env.local scripts/import-yahoo-historical.mjs RELIANCE.NS",
    "yahoo:dry-run": "node --env-file=.env.local scripts/import-yahoo-dry-run.mjs",
    "yahoo:dry-run:reliance": "node --env-file=.env.local scripts/import-yahoo-dry-run.mjs RELIANCE.NS",
    "yahoo:batch": "node --env-file=.env.local scripts/import-yahoo-batch.mjs",
    "yahoo:batch:reliance": "node --env-file=.env.local scripts/import-yahoo-batch.mjs --stocks RELIANCE.NS",
    "yahoo:daily-update": "node --env-file=.env.local scripts/import-yahoo-daily-update.mjs --mode=daily_same_day_only",
    "yahoo:daily-update:reliance": "node --env-file=.env.local scripts/import-yahoo-daily-update.mjs --mode=daily_same_day_only --stocks=RELIANCE.NS --max-items=2",
    "yahoo:daily-update:same-day-only": "node --env-file=.env.local scripts/import-yahoo-daily-update.mjs --mode=daily_same_day_only",
    "yahoo:daily-update:same-day-only:reliance": "node --env-file=.env.local scripts/import-yahoo-daily-update.mjs --mode=daily_same_day_only --stocks=RELIANCE.NS --max-items=1",
    "stocks:build-nse-universe": "node --env-file=.env.local scripts/build-nse-stock-universe.mjs",
    "stocks:verify-canonical-resolver": "node --env-file=.env.local scripts/verify-canonical-stock-resolver.mjs",
    "stocks:generate-quality-summary": "node --env-file=.env.local scripts/generate-stock-data-quality-summary.mjs",
    "stocks:generate-freshness": "node --env-file=.env.local scripts/generate-stock-data-freshness.mjs",
    "preflight:hosted": "node scripts/verify-hosted-preflight.mjs",
    "validate:hosted-backfill": "node scripts/validate-hosted-public-backfill.mjs",
    "backfill:public-durable-sql": "node scripts/generate-public-durable-backfill-sql.mjs",
    "meilisearch:dev": "node scripts/run-meilisearch-dev.mjs",
    "trigger:dev": "node scripts/run-trigger-dev.mjs",
    "trigger:deploy": "trigger deploy --config trigger.config.ts"
  },
  "dependencies": {
    "@react-email/components": "^1.0.12",
    "@supabase/ssr": "^0.10.2",
    "@supabase/supabase-js": "^2.49.4",
    "@trigger.dev/sdk": "^4.4.4",
    "clsx": "^2.1.1",
    "lightweight-charts": "^5.1.0",
    "meilisearch": "^0.57.0",
    "next": "^16.0.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "resend": "^6.12.0",
    "trigger.dev": "^4.4.4"
  },
  "devDependencies": {
    "@types/node": "^24.6.0",
    "@types/react": "^19.2.2",
    "@types/react-dom": "^19.2.2",
    "autoprefixer": "^10.4.21",
    "postcss": "^8.5.6",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.9.3"
  }
}
